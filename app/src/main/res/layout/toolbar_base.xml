<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/indent_64">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="@dimen/indent_0"
        android:layout_height="@dimen/indent_0"
        android:background="@color/white"
        android:elevation="@dimen/indent_0"
        app:contentInsetStartWithNavigation="@dimen/indent_56"
        app:titleTextAppearance="@style/TextAppearance.Medium22"
        app:titleTextColor="@color/black_universal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="@dimen/indent_48"
        android:layout_height="@dimen/indent_48"
        android:layout_marginStart="@dimen/indent_4"
        android:layout_marginEnd="@dimen/indent_4"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back"
        android:scaleType="centerInside"
        android:src="@drawable/ic_arrow_back_24"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
