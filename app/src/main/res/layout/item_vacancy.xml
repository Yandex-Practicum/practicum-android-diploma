<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/padding_9">

    <ImageView
        android:id="@+id/companyIcon"
        android:layout_width="@dimen/item_icon"
        android:layout_height="@dimen/item_icon"
        android:src="@drawable/ic_placeholder_32"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/icon_view_shape"
        android:scaleType="centerInside"
        />

    <TextView
        android:id="@+id/vacancyName"
        style="@style/TextDisplayMedium22"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Разработчик платформы \nданных, Санкт-Петербург"
        app:layout_constraintStart_toEndOf="@+id/companyIcon"
        app:layout_constraintTop_toTopOf="parent"
        android:paddingStart="@dimen/padding_12"
        android:textColor="?attr/colorOnSurface"/>

    <TextView
        android:id="@+id/companyName"
        style="@style/TextDisplayRegular16"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Алиса"
        app:layout_constraintStart_toEndOf="@id/companyIcon"
        app:layout_constraintTop_toBottomOf="@id/vacancyName"
        android:paddingStart="@dimen/padding_12"
        android:textColor="?attr/colorOnSurface"/>


    <TextView
        android:id="@+id/salary"
        style="@style/TextDisplayRegular16"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="от 1 500 до 3 000 $"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/companyIcon"
        app:layout_constraintTop_toBottomOf="@id/companyName"
        android:paddingStart="@dimen/padding_12"
        android:textColor="?attr/colorOnSurface"/>


</androidx.constraintlayout.widget.ConstraintLayout>
