<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Тулбар -->
    <include
        android:id="@+id/include_toolbar"
        layout="@layout/toolbar_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/left_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="@dimen/dp_16" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/right_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="@dimen/dp_16" />

    <ImageButton
        android:id="@+id/button_like"
        android:src="@drawable/ic_favorites_off_24"
        android:background="@null"
        android:layout_width="@dimen/dp_48"
        android:layout_height="@dimen/dp_48"
        android:layout_marginTop="@dimen/dp_8"
        android:layout_marginEnd="@dimen/dp_8"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/button_share"
        android:src="@drawable/ic_share_24"
        android:background="@null"
        android:layout_width="@dimen/dp_48"
        android:layout_height="@dimen/dp_48"
        app:layout_constraintTop_toTopOf="@+id/button_like"
        app:layout_constraintEnd_toStartOf="@+id/button_like" />

    <TextView
        android:id="@+id/name"
        style="@style/TextAppearance.Bold32"
        android:textColorHint="@color/black"
        android:textColor="@color/black"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_88"
        app:layout_constraintStart_toStartOf="@+id/left_guideline"
        app:layout_constraintEnd_toStartOf="@+id/right_guideline"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Андроид разработчик" />

    <TextView
        android:id="@+id/salary"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        style="@style/TextAppearance.Medium22"
        android:textColorHint="@color/black"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@+id/name"
        app:layout_constraintStart_toStartOf="@+id/name"
        tools:text="от 3 000 $" />

    <View
        android:id="@+id/background_title"
        android:layout_width="@dimen/dp_0"
        android:layout_height="80dp"
        android:background="@drawable/edit_text_field"
        android:layout_marginTop="@dimen/dp_24"
        app:layout_constraintStart_toStartOf="@+id/left_guideline"
        app:layout_constraintEnd_toStartOf="@+id/right_guideline"
        app:layout_constraintTop_toBottomOf="@+id/salary" />

    <ImageView
        android:id="@+id/company_image"
        android:layout_width="@dimen/dp_48"
        android:layout_height="@dimen/dp_48"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginStart="@dimen/dp_16"
        app:layout_constraintStart_toStartOf="@+id/background_title"
        app:layout_constraintTop_toTopOf="@+id/background_title" />

    <TextView
        android:id="@+id/industry_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        style="@style/TextAppearance.Medium22"
        android:textColorHint="@color/black"
        android:textColor="@color/black"
        android:layout_marginEnd="@dimen/dp_8"
        android:ellipsize="end"
        android:layout_marginStart="@dimen/dp_8"
        android:maxLines="1"
        app:layout_constraintTop_toTopOf="@+id/company_image"
        app:layout_constraintStart_toEndOf="@+id/company_image"
        app:layout_constraintEnd_toStartOf="@id/right_guideline"
        tools:text="Еда" />

    <TextView
        android:id="@+id/area_name"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        style="@style/TextAppearance.Regular16"
        android:textColorHint="@color/black"
        android:textColor="@color/black"
        android:layout_marginStart="@dimen/dp_8"
        android:layout_marginEnd="@dimen/dp_8"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintTop_toBottomOf="@+id/industry_name"
        app:layout_constraintEnd_toStartOf="@id/right_guideline"
        app:layout_constraintStart_toEndOf="@+id/company_image"
        tools:text="Москва" />

    <ImageView
        android:id="@+id/placeholder_not_found_vacancy"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        android:src="@drawable/img_vacancy_not_found"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/right_guideline"
        app:layout_constraintStart_toStartOf="@+id/left_guideline" />

    <TextView
        android:id="@+id/text_image_caption_not_found_vacancy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_16"
        style="@style/TextAppearance.Medium22"
        android:textColorHint="@color/black"
        android:textColor="@color/black"
        android:hint="@string/vacancy_not_found"
        android:visibility="gone"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/placeholder_not_found_vacancy"
        app:layout_constraintEnd_toStartOf="@+id/right_guideline"
        app:layout_constraintStart_toStartOf="@+id/left_guideline" />

    <ProgressBar
        android:id="@+id/progressBar_vacancy"
        android:layout_width="@dimen/dp_36"
        android:layout_height="@dimen/dp_36"
        android:layout_gravity="center"
        android:indeterminateTint="@color/blue"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/background_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_0"
        android:fillViewport="true"
        android:layout_marginTop="@dimen/dp_24"
        app:layout_constraintTop_toBottomOf="@+id/background_title"
        app:layout_constraintStart_toStartOf="@+id/left_guideline"
        app:layout_constraintEnd_toStartOf="@+id/right_guideline"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/experience"
                style="@style/TextAppearance.Medium16"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="@string/experience_title"
                android:textColorHint="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/experience_description"
                style="@style/TextAppearance.Regular16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="От 1 года до 3 лет" />

            <TextView
                android:id="@+id/schedule"
                style="@style/TextAppearance.Regular16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Полная занятость, Удаленная работа" />

            <TextView
                android:id="@+id/vacancy_description_title"
                style="@style/TextAppearance.Medium22"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/vacancy_description_title"
                android:textColorHint="@color/black"
                android:textColor="@color/black"
                android:layout_marginTop="@dimen/dp_32"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/duties"
                style="@style/TextAppearance.Medium16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColorHint="@color/black"
                android:textColor="@color/black"
                android:hint="@string/duties"
                android:layout_marginTop="@dimen/dp_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/duty_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/requirements"
                style="@style/TextAppearance.Medium16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColorHint="@color/black"
                android:textColor="@color/black"
                android:hint="@string/requirements"
                android:layout_marginTop="@dimen/dp_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/requirements_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/conditions"
                style="@style/TextAppearance.Medium16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColorHint="@color/black"
                android:textColor="@color/black"
                android:hint="@string/conditions"
                android:layout_marginTop="@dimen/dp_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/conditions_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/skills_title"
                style="@style/TextAppearance.Medium22"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColorHint="@color/black"
                android:hint="@string/skills_title"
                android:layout_marginTop="@dimen/dp_24"
                android:paddingBottom="@dimen/dp_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/skills_text"
                style="@style/TextAppearance.Regular16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:singleLine="false"
                android:ellipsize="none"
                android:visibility="visible"
                tools:text="  •  Kotlin\n  •  Java\n  •  Android SDK" />

            <TextView
                android:id="@+id/contacts_title"
                style="@style/TextAppearance.Medium22"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColorHint="@color/black"
                android:hint="@string/contacts_title"
                android:layout_marginTop="@dimen/dp_24"
                android:paddingBottom="@dimen/dp_16"
                android:visibility="gone" />

            <TextView
                android:id="@+id/contact_name"
                style="@style/TextAppearance.Regular16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:layout_marginBottom="@dimen/dp_8"
                android:visibility="gone"
                tools:text="Властелин Мира" />

            <TextView
                android:id="@+id/contact_email"
                style="@style/TextAppearance.Regular16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blue"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                tools:text="sutulaya@zadolbala.com" />

            <TextView
                android:id="@+id/contact_phone"
                style="@style/TextAppearance.Regular16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blue"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="@dimen/dp_8"
                android:visibility="gone"
                tools:text="+7 (890) 123-45-67" />

        </LinearLayout>

    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>
