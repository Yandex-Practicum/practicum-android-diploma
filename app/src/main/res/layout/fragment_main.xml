<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/title_height"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/job_search_text"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/merge_size"
            android:text="@string/job_search"
            android:textColor="?attr/attr_white_black_color"
            android:textSize="@dimen/text_size"
            tools:ignore="RtlSymmetry" />

        <ImageButton
            android:id="@+id/trailing_button"
            android:layout_width="@dimen/button_size"
            android:layout_height="@dimen/button_size"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/merge_size"
            android:background="@null"
            android:src="@drawable/trailing_icon"
            app:layout_constraintBottom_toBottomOf="parent" />
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginVertical="8dp">

        <EditText
            android:id="@+id/editSearchText"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/background_search_edit_text"
            android:drawableRight="@drawable/search_icon"
            android:drawablePadding="8dp"
            android:fontFamily="@font/ys_display_regular"
            android:hint="@string/hint_edit_text"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="16dp"
            android:singleLine="true"
            android:textAppearance="@style/textAppearanceRegular16sp400w"
            android:textColor="@color/black"
            android:textColorHint="?attr/hint_color_edit_text"
            android:textCursorDrawable="@drawable/cursor" />

        <ImageView
            android:id="@+id/clear_the_field"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="30dp"
            android:background="?attr/edit_text_background_color"
            android:contentDescription="@string/contentDescription"
            android:visibility="gone"
            app:srcCompat="@drawable/close_edit_text_search" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="16dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/items_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/background_notify_blue"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="найдено 283 вакансии"
                android:textAppearance="@style/textAppearanceRegular16sp400w"
                android:textColor="@color/white"
                android:visibility="gone"
                tools:text="найдено 283 вакансии" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/dataList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/search_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:contentDescription="@string/contentDescription"
                android:src="@drawable/image_search_default"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:textAppearance="@style/textAppearanceMedium22sp500w"
                android:textColor="?attr/attr_white_black_color"
                android:visibility="gone"
                tools:text="@string/not_internet" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_circular"
            android:layout_width="@dimen/button_size"
            android:layout_height="@dimen/button_size"
            android:layout_gravity="center"
            android:indeterminateTint="@color/blue"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
