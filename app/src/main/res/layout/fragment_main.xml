<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="72dp">

    <!-- Основной контент -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Существующий заголовок -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/title_height"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/job_search_text"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/merge_size"
                android:text="@string/job_search"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size"
                tools:ignore="RtlSymmetry" />

            <ImageButton
                android:id="@+id/trailing_button"
                android:layout_width="@dimen/button_size"
                android:layout_height="@dimen/button_size"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/merge_size"
                android:background="@null"
                android:src="@drawable/trailing_icon" />
        </RelativeLayout>

        <!-- TextInputLayout с OutlinedBox и крестиком -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/merge_size"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:boxStrokeColor="@color/grey"
            app:hintTextColor="@color/grey"
            app:endIconMode="clear_text"
            app:endIconTint="@color/grey"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/search_edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/search_hint"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:textColor="@color/black" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/results_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_medium"
            android:gravity="center"
            android:background="@drawable/bg_results_count"
            android:visibility="gone"
            android:layout_gravity="center_horizontal" />

        <!-- RecyclerView для вакансий -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/vacancies_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Состояния поверх основного контента -->

    <!-- Прогресс-бар загрузки (центрированный) -->
    <ProgressBar
        android:id="@+id/loading_progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/blue"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Состояние пустого запроса -->
    <TextView
        android:id="@+id/empty_state_text"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/empty_query_text"
        android:textColor="@color/black"
        android:textSize="@dimen/text_size_medium"
        android:visibility="gone" />

    <!-- Состояние ошибки -->
    <LinearLayout
        android:id="@+id/error_state_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="100dp">

        <!-- Картинка 328x223 -->
        <ImageView
            android:layout_width="328dp"
            android:layout_height="223dp"
            android:src="@drawable/ic_no_internet"
            android:contentDescription="@string/no_internet_content_description"
            android:layout_marginBottom="16dp" />

        <!-- Текст "Нет интернета" под картинкой -->
        <TextView
            android:id="@+id/error_state_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_internet_title"
            android:textColor="@color/black2"
            android:textSize="17sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Состояние нет результатов -->
    <LinearLayout
        android:id="@+id/no_results_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="100dp">

        <!-- Текст "Ничего не найдено" НАД картинкой - на синем фоне -->
        <TextView
            android:id="@+id/no_results_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_results_title"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_medium"
            android:gravity="center"
            android:background="@drawable/bg_results_count"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp" />

        <!-- Картинка 328x223 -->
        <ImageView
            android:layout_width="328dp"
            android:layout_height="223dp"
            android:src="@drawable/ic_no_results"
            android:contentDescription="@string/no_results_content_description"
            android:layout_marginBottom="16dp" />

        <!-- Дополнительный текст снизу -->
        <TextView
            android:id="@+id/no_results_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_results_subtitle"
            android:textColor="@color/black2"
            android:textSize="22sp"
            android:gravity="center"
            android:paddingStart="48dp"
            android:paddingEnd="48dp" />

    </LinearLayout>

</FrameLayout>
