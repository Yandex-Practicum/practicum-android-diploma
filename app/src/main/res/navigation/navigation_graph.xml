<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation_graph"
    app:startDestination="@id/jobSearchFragment">

    <fragment
        android:id="@+id/jobSearchFragment"
        android:name="ru.practicum.android.diploma.ui.job_search.fragment.JobSearchFragment"
        android:label="fragment_job_search"
        tools:layout="@layout/fragment_job_search" >
        <action
            android:id="@+id/action_jobSearchFragment_to_filtrationFragment"
            app:destination="@id/filtrationFragment" />
        <action
            android:id="@+id/action_jobSearchFragment_to_vacancyFragment"
            app:destination="@id/vacancyFragment" />
    </fragment>
    <fragment
        android:id="@+id/favoritesFragment"
        android:name="ru.practicum.android.diploma.ui.favorites.fragment.FavoritesFragment"
        android:label="fragment_favorites"
        tools:layout="@layout/fragment_favorites" />
    <fragment
        android:id="@+id/teamFragment"
        android:name="ru.practicum.android.diploma.ui.team.TeamFragment"
        android:label="fragment_team"
        tools:layout="@layout/fragment_team" />
    <fragment
        android:id="@+id/filtrationFragment"
        android:name="ru.practicum.android.diploma.ui.filtration.FiltrationFragment"
        android:label="fragment_filtration"
        tools:layout="@layout/fragment_filtration" >
        <action
            android:id="@+id/action_filtrationFragment_to_placeOfWorkFragment"
            app:destination="@id/placeOfWorkFragment" />
        <action
            android:id="@+id/action_filtrationFragment_to_industrySelectionFragment"
            app:destination="@id/industrySelectionFragment" />
    </fragment>
    <fragment
        android:id="@+id/placeOfWorkFragment"
        android:name="ru.practicum.android.diploma.ui.filtration.place_of_work.PlaceOfWorkFragment"
        android:label="fragment_place_of_work"
        tools:layout="@layout/fragment_place_of_work" >
        <action
            android:id="@+id/action_placeOfWorkFragment_to_chooseCountryFragment"
            app:destination="@id/chooseCountryFragment" />
        <action
            android:id="@+id/action_placeOfWorkFragment_to_chooseRegionFragment"
            app:destination="@id/chooseRegionFragment" />
    </fragment>
    <fragment
        android:id="@+id/chooseCountryFragment"
        android:name="ru.practicum.android.diploma.ui.filtration.choose_country.ChooseCountryFragment"
        android:label="fragment_choose_country"
        tools:layout="@layout/fragment_choose_country" />
    <fragment
        android:id="@+id/chooseRegionFragment"
        android:name="ru.practicum.android.diploma.ui.filtration.choose_region.ChooseRegionFragment"
        android:label="fragment_choose_region"
        tools:layout="@layout/fragment_choose_region" />
    <fragment
        android:id="@+id/industrySelectionFragment"
        android:name="ru.practicum.android.diploma.ui.filtration.industry_selection.IndustrySelectionFragment"
        android:label="fragment_industry_selection"
        tools:layout="@layout/fragment_industry_selection" />
    <fragment
        android:id="@+id/vacancyFragment"
        android:name="ru.practicum.android.diploma.ui.vacancy.VacancyFragment"
        android:label="fragment_vacancy"
        tools:layout="@layout/fragment_vacancy" />
</navigation>
