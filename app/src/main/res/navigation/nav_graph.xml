<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/searchFragment">

    <fragment
        android:id="@+id/searchFragment"
        android:name="ru.practicum.android.diploma.presentation.search.SearchFragment"
        android:label="Search" />

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="ru.practicum.android.diploma.presentation.favorites.FavoritesFragment"
        android:label="Favorites" />

    <fragment
        android:id="@+id/teamFragment"
        android:name="ru.practicum.android.diploma.presentation.team.TeamFragment"
        android:label="Team" />

    <fragment
        android:id="@+id/filterFragment"
        android:name="ru.practicum.android.diploma.presentation.filter.FilterFragment"
        android:label="Filter">
        <action
            android:id="@+id/action_filterFragment_to_industrySelectionFragment"
            app:destination="@id/industrySelectionFragment" />
    </fragment>

    <fragment
        android:id="@+id/industrySelectionFragment"
        android:name="ru.practicum.android.diploma.presentation.industry.IndustrySelectionFragment"
        android:label="Industry Selection">
        <argument
            android:name="preselectedIndustryId"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>

    <fragment
        android:id="@+id/vacancyDetailsFragment"
        android:name="ru.practicum.android.diploma.presentation.details.VacancyDetailsFragment"
        android:label="Vacancy Details">
        <argument
            android:name="vacancyId"
            app:argType="string" />
    </fragment>

</navigation>
