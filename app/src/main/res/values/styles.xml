<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ToolbarStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:maxHeight">@dimen/toolbar_height</item>
        <item name="titleTextAppearance">@style/TextDisplayMedium22</item>
        <item name="android:paddingVertical">@dimen/padding_19</item>
        <item name="contentInsetStart">0dp</item>
        <item name="contentInsetStartWithNavigation">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="inputEditTextSearchStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">@dimen/edit_text_height</item>
        <item name="android:paddingHorizontal">@dimen/padding_16</item>
        <item name="android:paddingVertical">@dimen/padding_12</item>
        <item name="android:maxLength">255</item>
        <item name="android:maxLines">1</item>
        <item name="android:inputType">text</item>
        <item name="android:textAppearance">@style/TextDisplayRegular16</item>
        <item name="android:background">@drawable/text_view_shape</item>
    </style>

    <style name="ButtonStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/max_button_height</item>
        <item name="android:textAlignment">center</item>
        <item name="android:paddingVertical">@dimen/padding_20</item>
        <item name="android:paddingHorizontal">@dimen/padding_8</item>
        <item name="android:textAppearance">@style/TextDisplayMedium16</item>
        <item name="cornerRadius">@dimen/edit_text_radius</item>
    </style>

    <style name="ButtonErrorStyle" parent="ButtonStyle">
        <item name="android:textColor">@color/red</item>
        <item name="backgroundTint">@color/color_background</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="BottomNavigStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/color_background</item>
        <item name="itemIconTint">@color/bottom_nav_colors</item>
        <item name="itemTextColor">@color/bottom_nav_colors</item>
        <item name="android:textAppearance">@style/TextDisplayRegular12</item>
        <!--        <item name="menu">@menu/bottom_nav_menu</item>
        раскомментировать в момент мержа с задачей по Bottom Navigation-->
    </style>

    <style name="TextViewErrorStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">@dimen/padding_30</item>
        <item name="android:paddingTop">@dimen/padding_143</item>
        <item name="android:textAppearance">@style/TextDisplayMedium22</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:drawablePadding">@dimen/padding_16</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:drawableTint">@null</item>
    </style>

    <style name="SelectTextViewStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">@style/TextDisplayRegular16</item>
        <item name="android:maxHeight">@dimen/max_text_view_height</item>
        <item name="android:paddingVertical">@dimen/padding_14.5</item>
    </style>

    <style name="UnselectedTextViewStyle" parent="SelectTextViewStyle">
        <item name="android:textColor">@color/color_text_secondary</item>
    </style>

    <style name="TextViewTeamHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">@style/TextDisplayBold32</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextViewTeamLine">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">@style/TextDisplayMedium16</item>
    </style>

    <style name="inputEditLayoutSumStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="expandedHintEnabled">false</item>
        <item name="hintEnabled">true</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
    </style>

    <style name="inputEditTextSumStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:maxHeight">@dimen/edit_text_height</item>
        <item name="android:paddingHorizontal">@dimen/padding_16</item>
        <item name="android:maxLength">255</item>
        <item name="android:maxLines">1</item>
        <item name="android:inputType">number</item>
        <item name="android:textAppearance">@style/TextDisplayRegular16</item>
        <item name="android:background">@drawable/text_view_shape</item>
    </style>

    <style name="TextDisplayMedium22">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_large</item>
        <item name="android:fontWeight">500</item>
    </style>

    <style name="TextDisplayMedium16">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_medium</item>
        <item name="android:fontWeight">500</item>
    </style>

    <style name="TextDisplayRegular16">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">@dimen/text_size_medium</item>
        <item name="android:fontWeight">400</item>
    </style>

    <style name="TextDisplayRegular12">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">@dimen/text_size_small</item>
        <item name="android:fontWeight">400</item>
    </style>

    <style name="TextDisplayBold32">
        <item name="android:fontFamily">@font/ys_display_bold</item>
        <item name="android:textSize">@dimen/text_size_big</item>
        <item name="android:fontWeight">700</item>
    </style>
</resources>
